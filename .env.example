#=======================================
# Oinbox Environment Variables
#=======================================
# Copie para .env e preencha com suas credenciais.
# Segredos de PRODUCAO devem ser configurados via wrangler secret put.

# --- Frontend ---
VITE_API_URL="http://localhost:8787"
VITE_STRIPE_PUBLIC_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"

# --- Backend (Segredos) ---
# Gere o JWT_SECRET com: openssl rand -base64 32
JWT_SECRET="YOUR_JWT_SECRET_GENERATE_WITH_OPENSSL_RAND_BASE64_32"

# --- AI ---
# Groq API (Llama, Mixtral - rapido e barato)
GROQ_API_KEY="YOUR_GROQ_API_KEY"
# OpenAI (fallback/alternativa)
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_API_KEY"
# Google Gemini (legado, nao mais usado)
# GOOGLE_GENAI_API_KEY="YOUR_GOOGLE_GENAI_API_KEY"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"

# --- Evolution API (WhatsApp) ---
# Desenvolvimento local: Evolution API via Docker (porta 8080)
# Veja: docker-compose.yml na raiz do projeto evolution-api (repositório separado)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="YOUR_EVOLUTION_API_KEY"
# Producao: apontar para VPS com tunnel Cloudflare
# EVOLUTION_API_URL="https://evolution.oinbox.oconnector.tech"

# --- Google APIs ---
GOOGLE_PLACES_API_KEY="YOUR_GOOGLE_PLACES_API_KEY"

# --- Google OAuth (opcional) ---
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# --- Datadog (opcional, observabilidade) ---
# DATADOG_API_KEY="YOUR_DATADOG_API_KEY"
