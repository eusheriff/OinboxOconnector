#=======================================
# Oinbox Environment Variables
#=======================================
# Copie para .env e preencha com suas credenciais.
# Segredos de PRODUCAO devem ser configurados via wrangler secret put.

# --- Frontend ---
VITE_API_URL="http://localhost:8787"
VITE_STRIPE_PUBLIC_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"

# --- Backend (Segredos) ---
# Gere o JWT_SECRET com: openssl rand -base64 32
JWT_SECRET="YOUR_JWT_SECRET_GENERATE_WITH_OPENSSL_RAND_BASE64_32"

# --- AI ---
# Groq API (Llama, Mixtral - rapido e barato)
SECONDARY_ENGINE_API_KEY="YOUR_SECONDARY_ENGINE_API_KEY"
# OpenAI (fallback/alternativa)
PRIMARY_ENGINE_API_KEY="sk-proj-YOUR_PRIMARY_ENGINE_API_KEY"
# Google Gemini (legado, nao mais usado)
# GOOGLE_GENAI_API_KEY="YOUR_GOOGLE_GENAI_API_KEY"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"

# --- Evolution API (WhatsApp) ---
# Desenvolvimento local: Evolution API via Docker (porta 8080)
# Veja: docker-compose.yml na raiz do projeto evolution-api (repositório separado)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="YOUR_EVOLUTION_API_KEY"
# Producao: apontar para VPS com tunnel Cloudflare
# EVOLUTION_API_URL="https://evolution.oinbox.oconnector.tech"

# --- Google APIs ---
GOOGLE_PLACES_API_KEY="YOUR_GOOGLE_PLACES_API_KEY"

# --- Meta / WhatsApp Cloud API (Oficial OAuth) ---
META_APP_ID="YOUR_META_APP_ID"
META_APP_SECRET="YOUR_META_APP_SECRET"
META_CONFIG_ID="YOUR_META_CONFIG_ID"
META_WEBHOOK_VERIFY_TOKEN="YOUR_RANDOM_VERIFY_TOKEN"
PUBLIC_WORKER_URL="http://localhost:8787"

# --- Google OAuth (opcional) ---
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# --- Facebook / Instagram (Messenger + Direct) ---
# Criar App em: https://developers.facebook.com/
# Perissoes necessarias: pages_manage_metadata, pages_messaging, pages_show_list, business_management
FACEBOOK_APP_ID="YOUR_FACEBOOK_APP_ID"
FACEBOOK_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"

# --- X (Twitter) ---
# Criar Project/App em: https://developer.twitter.com/
# Necessario: Account Activity API access (nivel Elevated ou superior)
X_CONSUMER_KEY="YOUR_X_CONSUMER_KEY"
X_CONSUMER_SECRET="YOUR_X_CONSUMER_SECRET"

# --- TikTok ---
# Criar App em: https://developers.tiktok.com/
# Perissoes: user.info.basic, imessage.send, imessage.receive
TIKTOK_CLIENT_KEY="YOUR_TIKTOK_CLIENT_KEY"
TIKTOK_CLIENT_SECRET="YOUR_TIKTOK_CLIENT_SECRET"

# --- Line ---
# Criar Channel em: https://developers.line.biz/console/
LINE_CHANNEL_ID="YOUR_LINE_CHANNEL_ID"
LINE_CHANNEL_SECRET="YOUR_LINE_CHANNEL_SECRET"

# --- Datadog (opcional, observabilidade) ---
# DATADOG_API_KEY="YOUR_DATADOG_API_KEY"

# --- Bancos de Dados Externos & Cache ---
# NEON_DATABASE_URL="https://.../rest/v1"
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="token..."
