#=======================================
# Oinbox Environment Variables
#=======================================

# --- Frontend ---
# URL completa para o backend do worker. Para desenvolvimento local, geralmente é http://localhost:8787.
# Em produção, será a URL do seu worker no Cloudflare.
VITE_API_URL="http://localhost:8787"

# URLs de produção (via Cloudflare Tunnel - ilimitado)
NEXT_PUBLIC_API_URL="https://api.oconnector.tech"
NEXT_PUBLIC_WHATSAPP_URL="https://your-whatsapp-worker.workers.dev"

# Chave publicável da API do Stripe (LIVE ou TEST)
VITE_STRIPE_PUBLIC_KEY="pk_live_YOUR_STRIPE_PUBLISHABLE_KEY"


# --- Backend (Segredos) ---
# ⚠️ IMPORTANTE: Em produção, configure estes valores como secrets no Cloudflare Workers:
#   wrangler secret put JWT_SECRET
#   wrangler secret put API_KEY
#   wrangler secret put STRIPE_SECRET_KEY
#   wrangler secret put STRIPE_WEBHOOK_SECRET
#   wrangler secret put GOOGLE_PLACES_API_KEY
#   wrangler secret put GOOGLE_GEMINI_API_KEY

# Chave secreta para assinar os JSON Web Tokens (JWT).
# Gere uma nova chave com: openssl rand -base64 32
JWT_SECRET="GENERATE_A_NEW_SECRET_WITH_openssl_rand_-base64_32"

# Chave de API para o Google Gemini
API_KEY="YOUR_GOOGLE_GEMINI_API_KEY"

# Chave secreta da API do Stripe
STRIPE_SECRET_KEY="sk_live_YOUR_STRIPE_SECRET_KEY"

# Segredo de assinatura do Webhook do Stripe
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"

# IDs de Preço do Stripe (Obtenha no Dashboard do Stripe > Products)
STRIPE_PRICE_PRO="price_YOUR_PRO_PRICE_ID"
STRIPE_PRICE_BASIC="price_YOUR_BASIC_PRICE_ID"

# --- Google OAuth ---
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# --- Google APIs ---
GOOGLE_PLACES_API_KEY="YOUR_GOOGLE_PLACES_API_KEY"
GOOGLE_GEMINI_API_KEY="YOUR_GOOGLE_GEMINI_API_KEY"

# --- Evolution API (WhatsApp) ---
# URL da sua instância Evolution API
EVOLUTION_API_URL="http://your-evolution-api:8080"

# Chave de API da Evolution API
EVOLUTION_API_KEY="YOUR_EVOLUTION_API_KEY"