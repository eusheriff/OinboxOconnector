{
  "name": "oinbox-saas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:backend": "wrangler dev",
    "build": "tsc && vite build",
    "build:backend": "tsc -p backend/tsconfig.json",
    "start:backend": "echo 'Use wrangler dev para desenvolvimento. Node.js mode requires D1/R2 adapters.' && exit 1",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist --project-name oinbox-frontend",
    "deploy:worker": "wrangler deploy",
    "db:setup": "wrangler d1 execute oinbox-db --file=./backend/schema.sql --local",
    "db:migrate": "bash -c 'for f in backend/migrations/*.sql; do echo \"Running $f\"; wrangler d1 execute oinbox-db --local --file=./$f; done'",
    "db:migrate:prod": "bash -c 'for f in backend/migrations/*.sql; do echo \"Running $f\"; wrangler d1 execute oinbox-db --file=./$f; done'",
    "health": "curl -sf http://localhost:8787/api/health | jq .",
    "test": "vitest run",
    "test:backend": "vitest run -c backend/vitest.config.ts",
    "test:frontend": "vitest run -c vite.config.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-google-maps/api": "^2.20.8",
    "@stripe/stripe-js": "^3.0.7",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.10.6",
    "html2canvas": "^1.4.1",
    "jose": "^6.1.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "postal-mime": "^2.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.9.6",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251121.0",
    "@datadog/datadog-ci": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.13",
    "@vitest/ui": "^4.0.13",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.13",
    "wrangler": "^4.81.1"
  }
}
