{
  "name": "oinbox-saas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "wrangler dev",
    "build": "tsc && vite build",
    "build:backend": "tsc -p backend/tsconfig.json",
    "start:backend": "node backend/dist/server.js",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "deploy:worker": "wrangler deploy",
    "db:setup": "wrangler d1 execute oconnector-db --file=./backend/schema.sql --local",
    "test": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "docker:build": "docker build -t oinbox-backend .",
    "docker:run": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@google/genai": "^1.30.0",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.19.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-google-maps/api": "^2.20.8",
    "@stripe/stripe-js": "^3.0.7",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.1",
    "cloudflare": "^5.2.0",
    "clsx": "^2.1.1",
    "hono": "^4.10.6",
    "html2canvas": "^1.4.1",
    "jose": "^6.1.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "postal-mime": "^2.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.9.6",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251121.0",
    "@datadog/datadog-ci": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "^4.0.13",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.13",
    "wrangler": "^3.114.15"
  }
}
